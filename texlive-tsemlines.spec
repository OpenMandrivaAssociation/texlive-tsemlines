%global tl_name tsemlines
%global tl_revision 23440

Name:		texlive-%{tl_name}
Epoch:		1
Version:	1.0
Release:	%{tl_revision}.1
Summary:	Support for the ancient \emline macro
Group:		Publishing
URL:		https://www.ctan.org/tex-archive/macros/latex/contrib/tsemlines
License:	pd
Source0:	https://mirrors.ctan.org/systems/texlive/tlnet/archive/tsemlines.r%{tl_revision}.tar.xz
BuildArch:	noarch
BuildSystem:	texlive
Provides:	texlive(%{tl_name}) = %{tl_revision}

%description
Occasional Documents appear, that use graphics generated by texcad from
the emtex distribution. These documents often use the \emline macro,
which produced lines at an arbitrary orientation. The present package
emulates the macro, using TikZ.

